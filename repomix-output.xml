<file path="apps/dashboard/src/app/globals.css">
@import "tailwindcss";

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: var(--font-inter);
}

:root {
  --background: oklch(0.145 0 0);
  --foreground: oklch(0.985 0 0);
  --card: oklch(0.205 0 0);
  --card-foreground: oklch(0.985 0 0);
  --accent: oklch(0.7 0.2 280);
  --accent-foreground: oklch(1 0 0);
  --border: oklch(1 0 0 / 10%);
}

body {
  background: var(--background);
  color: var(--foreground);
  font-family: var(--font-sans), sans-serif;
  min-height: 100vh;
  position: relative;
  overflow-x: hidden;
}

/* Cinematic Foundations */
.cinematic-bg {
  position: fixed;
  inset: 0;
  background: 
    radial-gradient(circle at 0% 0%, oklch(0.7 0.2 280 / 0.1), transparent 40%),
    radial-gradient(circle at 100% 100%, oklch(0.398 0.07 227.392 / 0.05), transparent 40%);
  z-index: -1;
  pointer-events: none;
}

/* Artistic Grid */
.art-grid {
  position: absolute;
  inset: 0;
  background-image: 
    linear-gradient(to right, oklch(1 0 0 / 0.02) 1px, transparent 1px),
    linear-gradient(to bottom, oklch(1 0 0 / 0.02) 1px, transparent 1px);
  background-size: 40px 40px;
  mask-image: radial-gradient(circle at center, black, transparent 80%);
  pointer-events: none;
}

/* Scanlines */
.scanlines {
  position: fixed;
  inset: 0;
  background-image: repeating-linear-gradient(
    0deg, 
    transparent, 
    transparent 2px, 
    oklch(1 0 0 / 0.01) 2px, 
    oklch(1 0 0 / 0.01) 3px
  );
  z-index: 100;
  pointer-events: none;
}

.glass-card {
  background: oklch(1 0 0 / 3%);
  backdrop-filter: blur(40px);
  border: 1px solid oklch(1 0 0 / 7%);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.glass-card:hover {
  background: oklch(1 0 0 / 5%);
  border-color: oklch(1 0 0 / 15%);
  box-shadow: 0 0 30px oklch(0.7 0.2 280 / 0.05);
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

.animate-float {
  animation: float 6s ease-in-out infinite;
}
</file>

