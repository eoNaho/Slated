{
  "name": "@kinofolio/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:generate": "bun x drizzle-kit generate",
    "db:migrate": "bun x drizzle-kit migrate",
    "db:push": "bun x drizzle-kit push",
    "db:studio": "bun x drizzle-kit studio",
    "migrate:tmdb-cdn": "bun run scripts/migrate-to-tmdb-cdn.ts",
    "migrate:tmdb-cdn:execute": "bun run scripts/migrate-to-tmdb-cdn.ts --execute"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.962.0",
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/openapi": "^1.4.14",
    "@node-rs/argon2": "^2.0.2",
    "@pixelreel/types": "workspace:*",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.36.0",
    "better-auth": "^1.5.5",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.2.9",
    "jose": "^6.1.3",
    "nodemailer": "^7.0.12",
    "otpauth": "^9.4.1",
    "path": "^0.12.7",
    "pino": "^10.1.0",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "resend": "^6.6.0",
    "sharp": "^0.34.5",
    "stripe": "^20.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.4",
    "@types/qrcode": "^1.5.6",
    "@types/sharp": "^0.32.0",
    "drizzle-kit": "^0.31.9",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.7.2"
  }
}
